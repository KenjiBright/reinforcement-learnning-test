    </model>

    <model name="wall_top_inner">
      <static>true</static><pose>3.25 1.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>10.5 0.5 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>10.5 0.5 1.0</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Brick</name></script></material>
        </visual>
      </link>
    </model>

    <model name="wall_right_outer">
      <static>true</static><pose>11.5 5.25 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.5 13.5 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.5 13.5 1.0</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Brick</name></script></material>
        </visual>
