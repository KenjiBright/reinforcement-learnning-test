<?xml version="1.0"?>
<robot name="robot_4wd_demo" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="chassis_len"    value="0.30"/>
  <xacro:property name="chassis_width"  value="0.20"/>
  <xacro:property name="chassis_height" value="0.08"/>
  <xacro:property name="wheel_radius"   value="0.05"/>
  <xacro:property name="wheel_thick"    value="0.04"/>

  <xacro:macro name="box_inertia" params="m w l h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(h*h+w*w)/12}" ixy="0" ixz="0"
               iyy="${m*(l*l+h*h)/12}" iyz="0"
               izz="${m*(l*l+w*w)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <material name="blue"><color rgba="0.0 0.2 0.8 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <link name="chassis">
    <visual>
      <geometry><box size="${chassis_len} ${chassis_width} ${chassis_height}"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="${chassis_len} ${chassis_width} ${chassis_height}"/></geometry>
    </collision>
    <xacro:box_inertia m="4.0" w="${chassis_width}" l="${chassis_len}" h="${chassis_height}"/>
  </link>

  <xacro:macro name="drive_wheel" params="prefix x_pos y_pos">
    <link name="${prefix}_wheel_link">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_thick}"/></geometry>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_thick}"/></geometry>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      </collision>
      <xacro:cylinder_inertia m="0.8" r="${wheel_radius}" h="${wheel_thick}"/>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="chassis"/>
      <child  link="${prefix}_wheel_link"/>
      <origin xyz="${x_pos} ${y_pos} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="10" velocity="25"/>
      <dynamics damping="0.05" friction="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="fl" x_pos=" 0.10" y_pos=" 0.12"/>
  <xacro:drive_wheel prefix="fr" x_pos=" 0.10" y_pos="-0.12"/>
  <xacro:drive_wheel prefix="rl" x_pos="-0.10" y_pos=" 0.12"/>
  <xacro:drive_wheel prefix="rr" x_pos="-0.10" y_pos="-0.12"/>

  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.05"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.05"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.2" r="0.04" h="0.05"/>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="chassis"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 ${chassis_height/2 + 0.025}" rpy="0 0 0"/>
  </joint>

</robot>